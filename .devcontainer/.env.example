# Example environment file for devcontainer certificate injection
#
# You can also set these variables on your host machine before launching the devcontainer:
#   export CERT_BASE64=your_base64_encoded_certificate_here
#   export CERT_NAME=your_certificate_name_here
# This achieves the same effect as using a .env file.

# Base64-encoded certificate string
CERT_BASE64=your_base64_encoded_certificate_here

# Certificate file name (e.g., Company-CA-RSA.crt)
CERT_NAME=your_certificate_name_here